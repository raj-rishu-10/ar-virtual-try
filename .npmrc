# pnpm workspace configuration
# These options are pnpm-specific — always use `pnpm` not `npm` to run scripts

# Restrict which packages run their install scripts (postinstall/preinstall)
# to prevent untrusted packages from executing arbitrary code
# only-built-dependencies[]=esbuild
# only-built-dependencies[]=turbo

# Ensure strict workspace protocol
# strict-peer-dependencies=false
# auto-install-peers=true
